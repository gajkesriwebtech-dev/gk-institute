import { NextResponse } from 'next/server';
import type { NextRequest } from 'next/server';
import { jwtVerify } from 'jose';
import { getAuthCookieOptions } from '@/lib/server/cookies';

const AUTH_COOKIE_NAME = 'auth_token';
const JWT_SECRET = process.env.JWT_SECRET;
const JWT_KEY = JWT_SECRET ? new TextEncoder().encode(JWT_SECRET) : null;

type AuthPayload = {
  sub: string;
  email: string;
  role: 'student' | 'admin';
};

export async function middleware(req: NextRequest) {
  const path = req.nextUrl.pathname;
  const isProtected = path.startsWith('/dashboard') || path.startsWith('/admin');
  const isAdmin = path.startsWith('/admin');

  if (isProtected) {
    const token = req.cookies.get(AUTH_COOKIE_NAME)?.value;

    if (!token) {
      return NextResponse.redirect(new URL('/login', req.url));
    }

    if (!JWT_KEY) {
      return NextResponse.redirect(new URL('/login', req.url));
    }

    try {
      const { payload } = await jwtVerify(token, JWT_KEY);
      const auth = payload as unknown as AuthPayload;

      // Role Based Access Control
      if (isAdmin && auth.role !== 'admin') {
        return NextResponse.redirect(new URL('/dashboard', req.url));
      }
    } catch {
      const response = NextResponse.redirect(new URL('/login', req.url));
      response.cookies.set(AUTH_COOKIE_NAME, '', getAuthCookieOptions(0));
      return response;
    }
  }

  return NextResponse.next();
}

export const config = {
  matcher: ['/dashboard/:path*', '/admin/:path*'],
};
