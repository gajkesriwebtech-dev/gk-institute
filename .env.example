NODE_ENV=production

# Public (safe to expose in browser bundles)
NEXT_PUBLIC_SITE_URL=https://institute.gkwebtech.cloud
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net
MONGODB_DB_NAME=edusaas

# Auth
JWT_SECRET=replace_with_a_long_random_secret
AUTH_COOKIE_DOMAIN=institute.gkwebtech.cloud

# Internal admin verification
INTERNAL_ADMIN_SECRET=replace_with_a_long_random_secret

# Email
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USER=contact@gkwebtech.cloud
EMAIL_PASS=replace_with_email_password
EMAIL_FROM="GK Institute <contact@gkwebtech.cloud>"
CONTACT_RECEIVER_EMAIL=contact@gkwebtech.cloud

# Stripe (optional; keep empty to disable)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
